# VibeMatch environment variables
# Copy this file to .env and fill in your values.

# Vibe Proxy URL (OpenAI-compatible endpoint)
VIBE_PROXY=https://vibe_proxy_server_here

# Vibe Proxy API key (required)
VIBE_KEY=your_vibe_key_here

# Optional: comma-separated allowed CORS origins (defaults to localhost + Vercel)
# CORS_ORIGINS=http://localhost:3000,https://your-domain.vercel.app

# Optional: server port (local dev only)
# PORT=3000
